# NodeGuard git ignore
# Keep source, docs, package manifests, and safe examples tracked.
# Ignore generated output, local secrets, runtime monitor data, and machine-specific files.

###############################################################################
# Dependencies
###############################################################################
node_modules/
**/node_modules/
.pnp/
.pnp.*

###############################################################################
# Environment files and secrets
###############################################################################
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.local

###############################################################################
# NodeGuard local runtime data
###############################################################################
apps/api/data/*.json
apps/api/data/*.sqlite
apps/api/data/*.sqlite3
apps/api/data/*.db
apps/api/data/*.db-journal

###############################################################################
# Build output and generated files
###############################################################################
dist/
**/dist/
build/
**/build/
web-build/
.next/
.nuxt/
.output/
coverage/
*.tsbuildinfo
vite.config.*.timestamp-*
expo-env.d.ts

###############################################################################
# Expo / React Native legacy generated state
###############################################################################
.expo/
.expo-shared/
android/
ios/
*.jks
*.keystore
*.mobileprovision
*.orig.*

###############################################################################
# Logs and diagnostics
###############################################################################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
nodeguard-diagnostics.json

###############################################################################
# Test, cache, and tool output
###############################################################################
.cache/
.parcel-cache/
.turbo/
.vite/
.eslintcache
.nyc_output/
playwright-report/
test-results/
storybook-static/

###############################################################################
# Editors and operating systems
###############################################################################
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

###############################################################################
# Docker / deployment local overrides
###############################################################################
docker-compose.override.yml
compose.override.yml
*.pid
*.sock
