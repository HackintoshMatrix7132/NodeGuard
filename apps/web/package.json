{
  "name": "@nodeguard/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run typecheck && tsx --test src/components/MonitoredExternalLink.test.tsx src/components/ProxmoxDashboardCard.test.ts src/components/ProxmoxNodeDetail.test.tsx src/utils/agentCommand.test.ts src/utils/updatePresentation.test.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.81.5",
    "lucide-react": "^0.468.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "vite": "^6.0.3"
  }
}
