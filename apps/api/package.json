{
  "name": "@nodeguard/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/index.js",
    "clean:build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:test": "node -e \"require('node:fs').rmSync('dist-test', { recursive: true, force: true })\"",
    "build": "npm run clean:build && tsc -p tsconfig.build.json",
    "build:test": "npm run clean:test && tsc -p tsconfig.test.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build:test && node --test \"dist-test/**/*.test.js\"",
    "db:backup": "node dist/cli/databaseMaintenance.js backup",
    "db:verify": "node dist/cli/databaseMaintenance.js verify",
    "db:restore": "node dist/cli/databaseMaintenance.js restore"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dockerode": "^5.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "systeminformation": "^5.23.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "typescript": "~5.9.2"
  }
}
